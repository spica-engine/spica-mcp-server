{
  "name": "@spica/mcp",
  "version": "0.18.10",
  "description": "MCP server for AI agents to interact with Spica servers — manage resources, databases, functions, storage, auditing, debugging and more.",
  "license": "ISC",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "spica-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "mcp",
    "spica",
    "model-context-protocol",
    "ai",
    "llm",
    "agent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spicaengine/spica-mcp-server.git"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --target node22 --out-dir dist --clean",
    "prestart": "npm run build",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.0"
  }
}
